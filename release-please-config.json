{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "bump-minor-pre-major": true,
  "separate-pull-requests": true,
  "initial-version": "0.1.0",
  "packages": {
    "scripts/cz": {
      "extra-files": [
        { "type": "generic", "path": "default.nix" },
        { "type": "generic", "path": "options.sh" },
        { "type": "generic", "path": "docs/cz.adoc" },
        { "type": "generic", "path": "docs/gitcommitizen.adoc" }
      ]
    },
    "scripts/dotenv": {
      "extra-files": [
        { "type": "generic", "path": "default.nix" },
        { "type": "generic", "path": "options.sh" },
        { "type": "generic", "path": "docs/dotenv.adoc" },
        { "type": "generic", "path": "docs/env.adoc" }
      ]
    },
    "scripts/theme": {
      "extra-files": [
        { "type": "generic", "path": "default.nix" },
        { "type": "generic", "path": "options.sh" },
        { "type": "generic", "path": "docs/theme.adoc" }
      ]
    }
  }
}
