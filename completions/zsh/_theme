#compdef theme

_theme() {
	local context state line
	typeset -A opt_args

	_arguments -C \
		'--detect[Only detect appearance, do not run handlers]' \
		'--list[List discovered provider and handlers]' \
		'(-h --help)'{-h,--help}'[Show help message]' \
		'--version[Show version]' \
		'1:appearance:(dark light)'
}

_theme "$@"
