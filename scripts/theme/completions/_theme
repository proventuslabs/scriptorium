#compdef theme

_theme() {
	local context state line
	typeset -A opt_args

	_arguments -C \
		'(-d --detect)'{-d,--detect}'[Only detect appearance, do not run handlers]' \
		'(-l --list)'{-l,--list}'[List discovered provider and handlers]' \
		'(-q --quiet)'{-q,--quiet}'[Suppress warnings]' \
		'(-h --help)'{-h,--help}'[Show help message]' \
		'(-V --version)'{-V,--version}'[Show version]' \
		'1:appearance:(dark light auto)'
}

_theme "$@"
