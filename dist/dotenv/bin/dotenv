#!/usr/bin/env bash

set -euo pipefail

# --- keep from: scripts/dotenv/options.sh ---
VERSION=0.1.0 # x-release-please-version

# Initialize defaults
# Helper for array accumulation (used by parser)
append_env_file() {
	ENV_FILES+=("$OPTARG")
}
# --- begin: gengetoptions parser -f ./options.sh parser_definition parse ---
# Generated by getoptions (BEGIN)
# URL: https://github.com/ko1nksm/getoptions (v3.3.2)
ENV_FILES=()
EXEC_MODE=''
STRICT=''
QUIET=''
REST=''
parse() {
	OPTIND=$(($#+1))
	while OPTARG= && [ "${REST}" != x ] && [ $# -gt 0 ]; do
		set -- "${1%%\=*}" "${1#*\=}" "$@"
		while [ ${#1} -gt 2 ]; do
			case $1 in (*[!a-zA-Z0-9_-]*) break; esac
			case '--env-file' in
				"$1") OPTARG=; break ;;
				$1*) OPTARG="$OPTARG --env-file"
			esac
			case '--exec' in
				"$1") OPTARG=; break ;;
				$1*) OPTARG="$OPTARG --exec"
			esac
			case '--strict' in
				"$1") OPTARG=; break ;;
				$1*) OPTARG="$OPTARG --strict"
			esac
			case '--quiet' in
				"$1") OPTARG=; break ;;
				$1*) OPTARG="$OPTARG --quiet"
			esac
			case '--help' in
				"$1") OPTARG=; break ;;
				$1*) OPTARG="$OPTARG --help"
			esac
			case '--version' in
				"$1") OPTARG=; break ;;
				$1*) OPTARG="$OPTARG --version"
			esac
			break
		done
		case ${OPTARG# } in
			*\ *)
				eval "set -- $OPTARG $1 $OPTARG"
				OPTIND=$((($#+1)/2)) OPTARG=$1; shift
				while [ $# -gt "$OPTIND" ]; do OPTARG="$OPTARG, $1"; shift; done
				set "Ambiguous option: $1 (could be $OPTARG)" ambiguous "$@"
				echo "$1" >&2
				exit 1 ;;
			?*)
				[ "$2" = "$3" ] || OPTARG="$OPTARG=$2"
				shift 3; eval 'set -- "${OPTARG# }"' ${1+'"$@"'}; OPTARG= ;;
			*) shift 2
		esac
		case $1 in
			--?*=*) OPTARG=$1; shift
				eval 'set -- "${OPTARG%%\=*}" "${OPTARG#*\=}"' ${1+'"$@"'}
				;;
			--no-*|--without-*) unset OPTARG ;;
			-[e]?*) OPTARG=$1; shift
				eval 'set -- "${OPTARG%"${OPTARG#??}"}" "${OPTARG#??}"' ${1+'"$@"'}
				;;
			-[xsqhV]?*) OPTARG=$1; shift
				eval 'set -- "${OPTARG%"${OPTARG#??}"}" -"${OPTARG#??}"' ${1+'"$@"'}
				case $2 in --*) set -- "$1" unknown "$2" && REST=x; esac;OPTARG= ;;
		esac
		case $1 in
			'-e'|'--env-file')
				[ $# -le 1 ] && set "required" "$1" && break
				OPTARG=$2
				append_env_file
				shift ;;
			'-x'|'--exec')
				[ "${OPTARG:-}" ] && OPTARG=${OPTARG#*\=} && set "noarg" "$1" && break
				eval '[ ${OPTARG+x} ] &&:' && OPTARG='1' || OPTARG=''
				EXEC_MODE="$OPTARG"
				;;
			'-s'|'--strict')
				[ "${OPTARG:-}" ] && OPTARG=${OPTARG#*\=} && set "noarg" "$1" && break
				eval '[ ${OPTARG+x} ] &&:' && OPTARG='1' || OPTARG=''
				STRICT="$OPTARG"
				;;
			'-q'|'--quiet')
				[ "${OPTARG:-}" ] && OPTARG=${OPTARG#*\=} && set "noarg" "$1" && break
				eval '[ ${OPTARG+x} ] &&:' && OPTARG='1' || OPTARG=''
				QUIET="$OPTARG"
				;;
			'-h'|'--help')
				usage
				exit 0 ;;
			'-V'|'--version')
				echo "${VERSION}"
				exit 0 ;;
			--)
				shift
				while [ $# -gt 0 ]; do
					REST="${REST} \"\${$(($OPTIND-$#))}\""
					shift
				done
				break ;;
			[-]?*) set "unknown" "$1"; break ;;
			*)
				while [ $# -gt 0 ]; do
					REST="${REST} \"\${$(($OPTIND-$#))}\""
					shift
				done
				break ;;
		esac
		shift
	done
	[ $# -eq 0 ] && { OPTIND=1; unset OPTARG; return 0; }
	case $1 in
		unknown) set "Unrecognized option: $2" "$@" ;;
		noarg) set "Does not allow an argument: $2" "$@" ;;
		required) set "Requires an argument: $2" "$@" ;;
		pattern:*) set "Does not match the pattern (${1#*:}): $2" "$@" ;;
		notcmd) set "Not a command: $2" "$@" ;;
		*) set "Validation error ($1): $2" "$@"
	esac
	echo "$1" >&2
	exit 1
}
usage() {
cat<<-'GETOPTIONSHERE'
Usage: dotenv [options...] command [args...]

Load environment from .env files and execute command

Options:
  -e, --env-file FILE         .env file to load (repeatable)
  -x, --exec                  Replace process with exec
  -s, --strict                Fail on warnings
  -q, --quiet                 Suppress warnings
  -h, --help                  
  -V, --version               
GETOPTIONSHERE
}
# Generated by getoptions (END)
# --- end: gengetoptions parser -f ./options.sh parser_definition parse ---

# --- begin: scripts/dotenv/dotenv.sh ---


# --- begin: scripts/dotenv/parser.sh ---

_SQ_ESCAPE="'\\''"

parse_env() {
	local callback=$1
	local line key value
	local in_single_quote=false
	local in_double_quote=false
	local accumulated_value=""
	local current_key=""
	local had_warnings=false

	while IFS= read -r line || [[ -n "$line" ]]; do
		if $in_single_quote || $in_double_quote; then
			accumulated_value+=$'\n'"$line"

			if $in_single_quote; then
				if _ends_single_quote "$accumulated_value"; then
					value=$(_extract_single_quoted "$accumulated_value")
					"$callback" "$current_key" "$value"
					in_single_quote=false
					current_key=""
					accumulated_value=""
				fi
			elif $in_double_quote; then
				if _ends_double_quote "$accumulated_value"; then
					value=$(_extract_double_quoted "$accumulated_value")
					value=$(_process_escapes "$value")
					value=$(_substitute_vars "$value")
					"$callback" "$current_key" "$value"
					in_double_quote=false
					current_key=""
					accumulated_value=""
				fi
			fi
			continue
		fi

		[[ "$line" =~ ^[[:space:]]*$ ]] && continue

		[[ "$line" =~ ^[[:space:]]*# ]] && continue

		if [[ "$line" =~ ^([a-zA-Z_][a-zA-Z0-9_]*)= ]]; then
			key="${BASH_REMATCH[1]}"
			value="${line#*=}"

			if [[ "$value" =~ ^\'(.*)\'([[:space:]]*(#.*)?)?$ ]] && [[ "${value: -4}" != "$_SQ_ESCAPE" ]]; then
				value="${BASH_REMATCH[1]}"
				value="${value//\'\\\'\'/\'}"
				"$callback" "$key" "$value"
			elif [[ "$value" =~ ^\' ]]; then
				in_single_quote=true
				current_key="$key"
				accumulated_value="$value"
			elif [[ "$value" =~ ^\"(.*)\"([[:space:]]*(#.*)?)?$ ]]; then
				value="${BASH_REMATCH[1]}"
				value=$(_process_escapes "$value")
				value=$(_substitute_vars "$value")
				"$callback" "$key" "$value"
			elif [[ "$value" =~ ^\" ]]; then
				in_double_quote=true
				current_key="$key"
				accumulated_value="$value"
			else
				value=$(_parse_unquoted "$value")
				"$callback" "$key" "$value"
			fi
		elif [[ "$line" =~ ^[0-9] ]]; then
			[[ -z "${DOTENV_QUIET:-}" ]] && echo "dotenv: warning: invalid key starting with digit: ${line%%=*}" >&2
			had_warnings=true
		else
			[[ -z "${DOTENV_QUIET:-}" ]] && echo "dotenv: warning: unrecognized line: $line" >&2
			had_warnings=true
		fi
	done

	if $in_single_quote; then
		[[ -z "${DOTENV_QUIET:-}" ]] && echo "dotenv: warning: unclosed single quote for key: $current_key" >&2
		had_warnings=true
		value="${accumulated_value#\'}"
		"$callback" "$current_key" "$value"
	elif $in_double_quote; then
		[[ -z "${DOTENV_QUIET:-}" ]] && echo "dotenv: warning: unclosed double quote for key: $current_key" >&2
		had_warnings=true
		value="${accumulated_value#\"}"
		value=$(_process_escapes "$value")
		value=$(_substitute_vars "$value")
		"$callback" "$current_key" "$value"
	fi

	$had_warnings && return 1
	return 0
}

_ends_single_quote() {
	local s=$1
	[[ "${s: -4}" == "$_SQ_ESCAPE" ]] && return 1
	[[ "$s" == *"'"*"#"* ]] && s="${s%%"'"*"#"*}'"
	s="${s%"${s##*[![:space:]]}"}"
	[[ "${s: -1}" == "'" ]]
}

_ends_double_quote() {
	local s=$1
	local len=${#s}
	local i=$((len - 1))

	while [[ $i -ge 0 ]]; do
		local char="${s:$i:1}"
		if [[ "$char" == '"' ]]; then
			local backslashes=0
			local j=$((i - 1))
			while [[ $j -ge 0 && "${s:$j:1}" == '\' ]]; do
				((backslashes++))
				((j--))
			done
			if ((backslashes % 2 == 0)); then
				return 0
			fi
		fi
		((i--))
	done
	return 1
}

_extract_single_quoted() {
	local s=$1
	s="${s#\'}"
	s="${s%\'*}"
	s="${s//\'\\\'\'/\'}"
	printf '%s' "$s"
}

_extract_double_quoted() {
	local s=$1
	s="${s#\"}"
	local result=""
	local i=0
	local len=${#s}

	while [[ $i -lt $len ]]; do
		local char="${s:$i:1}"
		if [[ "$char" == '\' && $((i + 1)) -lt $len ]]; then
			local next="${s:$((i + 1)):1}"
			result+="$char$next"
			((i += 2))
		elif [[ "$char" == '"' ]]; then
			break
		else
			result+="$char"
			((i++))
		fi
	done

	printf '%s' "$result"
}

_parse_unquoted() {
	local value=$1

	if [[ "$value" =~ ^([^#]*[^[:space:]])[[:space:]]+#.*$ ]]; then
		value="${BASH_REMATCH[1]}"
	elif [[ "$value" =~ ^([^#]*)[[:space:]]*#.*$ ]]; then
		value="${BASH_REMATCH[1]}"
	fi

	value="${value#"${value%%[![:space:]]*}"}"
	value="${value%"${value##*[![:space:]]}"}"

	printf '%s' "$value"
}

_process_escapes() {
	local value=$1
	local result=""
	local i=0
	local len=${#value}

	while [[ $i -lt $len ]]; do
		local char="${value:$i:1}"
		if [[ "$char" == '\' && $((i + 1)) -lt $len ]]; then
			local next="${value:$((i + 1)):1}"
			case "$next" in
				n) result+=$'\n' ;;
				t) result+=$'\t' ;;
				r) result+=$'\r' ;;
				f) result+=$'\f' ;;
				b) result+=$'\b' ;;
				v) result+=$'\v' ;;
				\\) result+='\' ;;
				'"') result+='"' ;;
				*) result+="\\$next" ;;
			esac
			((i += 2))
		else
			result+="$char"
			((i++))
		fi
	done

	printf '%s' "$result"
}

_substitute_vars() {
	local value=$1
	local result=""
	local i=0
	local len=${#value}

	while [[ $i -lt $len ]]; do
		local char="${value:$i:1}"
		if [[ "$char" == '$' && $((i + 1)) -lt $len ]]; then
			local next="${value:$((i + 1)):1}"
			if [[ "$next" == '{' ]]; then
				local rest="${value:$((i + 2))}"
				if [[ "$rest" =~ ^([a-zA-Z_][a-zA-Z0-9_]*):-([^}]*)\}(.*)$ ]]; then
					local varname="${BASH_REMATCH[1]}"
					local default="${BASH_REMATCH[2]}"
					local varvalue="${!varname:-}"
					if [[ -z "$varvalue" ]]; then
						result+="$default"
					else
						result+="$varvalue"
					fi
					((i += 2 + ${#varname} + 2 + ${#default} + 1))
				elif [[ "$rest" =~ ^([a-zA-Z_][a-zA-Z0-9_]*)\}(.*)$ ]]; then
					local varname="${BASH_REMATCH[1]}"
					local varvalue="${!varname:-}"
					result+="$varvalue"
					((i += 2 + ${#varname} + 1))
				else
					result+='$'
					((i++))
				fi
			elif [[ "$next" =~ ^[a-zA-Z_] ]]; then
				local rest="${value:$((i + 1))}"
				if [[ "$rest" =~ ^([a-zA-Z_][a-zA-Z0-9_]*)(.*)$ ]]; then
					local varname="${BASH_REMATCH[1]}"
					local varvalue="${!varname:-}"
					result+="$varvalue"
					((i += 1 + ${#varname}))
				else
					result+='$'
					((i++))
				fi
			else
				result+='$'
				((i++))
			fi
		else
			result+="$char"
			((i++))
		fi
	done

	printf '%s' "$result"
}
# --- end: scripts/dotenv/parser.sh ---

dotenv_warn() {
	[[ -n "${DOTENV_QUIET:-}" ]] && return 0
	echo "dotenv: warning: $1" >&2
	return 0
}

dotenv_exec() {
	local num_files=$1
	shift

	local -a env_files=("${@:1:num_files}")
	shift "$num_files"

	local -a env_args=()
	declare -A env_vars=()

	_dotenv_callback() {
		env_vars[$1]=$2
	}

	for file in "${env_files[@]}"; do
		if [[ ! -f "$file" ]]; then
			dotenv_warn "file not found: $file"
			[[ -n "${DOTENV_STRICT:-}" ]] && return 1
			continue
		fi
		if ! parse_env _dotenv_callback <"$file"; then
			[[ -n "${DOTENV_STRICT:-}" ]] && return 1
		fi
	done

	for key in "${!env_vars[@]}"; do
		[[ -z "${!key+x}" ]] && env_args+=("$key=${env_vars[$key]}")
	done

	if [[ -n "${DOTENV_EXEC:-}" ]]; then
		exec env "${env_args[@]}" "$@"
	else
		env "${env_args[@]}" "$@"
	fi
}
# --- end: scripts/dotenv/dotenv.sh ---

parse "$@" || exit 2
eval "set -- $REST"

if [[ $# -eq 0 ]]; then
	echo "dotenv: error: command required" >&2
	exit 2
fi

[[ ${#ENV_FILES[@]} -eq 0 ]] && ENV_FILES=(.env)

DOTENV_STRICT="$STRICT"
DOTENV_QUIET="$QUIET"
DOTENV_EXEC="$EXEC_MODE"

dotenv_exec "${#ENV_FILES[@]}" "${ENV_FILES[@]}" "$@"
