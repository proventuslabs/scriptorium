		usage() {
		cat<<-'GETOPTIONSHERE'
		Usage: cz init [options...]

		Generate a starter .gitcommitizen file

		Options:
		  -o, --output OUTPUT_FILE    Write to file instead of stdout
		  -f, --force                 Overwrite existing file
		  -h, --help                  
		GETOPTIONSHERE
		}
		# Generated by getoptions (END)
		# --- end: gengetoptions parser -f ./options.sh parser_definition_init parse_init ---
		parse_init "$@" || exit 2
		eval "set -- $REST"
		cmd_init
		;;
	hook)
		# --- keep from: scripts/cz/options.sh ---
		VERSION=0.1.0 # x-release-please-version
		# --- begin: gengetoptions parser -f ./options.sh parser_definition_hook parse_hook ---
