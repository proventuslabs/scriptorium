					esac
					case '--force' in
						"$1") OPTARG=; break ;;
						$1*) OPTARG="$OPTARG --force"
					esac
					case '--help' in
						"$1") OPTARG=; break ;;
						$1*) OPTARG="$OPTARG --help"
					esac
					break
				done
				case ${OPTARG# } in
					*\ *)
