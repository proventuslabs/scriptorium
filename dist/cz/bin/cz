						$1*) OPTARG="$OPTARG --files"
					esac
					case '--strict' in
						"$1") OPTARG=; break ;;
						$1*) OPTARG="$OPTARG --strict"
					esac
					case '--no-strict' in
						"$1") OPTARG=; break ;;
						$1*) OPTARG="$OPTARG --no-strict"
					esac
					case '--help' in
						"$1") OPTARG=; break ;;
						$1*) OPTARG="$OPTARG --help"
					esac
					break
				done
				case ${OPTARG# } in
