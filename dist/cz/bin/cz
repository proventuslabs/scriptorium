		usage() {
		cat<<-'GETOPTIONSHERE'
		Usage: cz lint [options...]

		Validate a commit message from stdin

		Options:
		  -q, --quiet                 Suppress output, exit status only
		  -h, --help                  
		GETOPTIONSHERE
		}
		# Generated by getoptions (END)
		# --- end: gengetoptions parser -f ./options.sh parser_definition_lint parse_lint ---
		parse_lint "$@" || exit 2
		eval "set -- $REST"
		cmd_lint
		;;
	init)
