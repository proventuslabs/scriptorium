				notcmd) set "Not a command: $2" "$@" ;;
				*) set "Validation error ($1): $2" "$@"
			esac
			echo "$1" >&2
			exit 1
		}
		usage() {
		cat<<-'GETOPTIONSHERE'
		Usage: cz init [options...]

		Generate a starter .gitcommitizen file

		Options:
		  -o, --output OUTPUT_FILE    Write to file instead of stdout
		  -f, --force                 Overwrite existing file
		  -h, --help                  
