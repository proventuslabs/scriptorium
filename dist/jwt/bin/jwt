#!/usr/bin/env bash

set -euo pipefail

# @start-kcov-exclude
# --- keep from: scripts/jwt/options.sh ---
VERSION=0.1.0 # x-release-please-version
# --- begin: gengetoptions parser -f ./options.sh parser_definition parse ---
# Generated by getoptions (BEGIN)
# URL: https://github.com/ko1nksm/getoptions (v3.3.2)
OUTPUT='payload'
OUTPUT=''
OUTPUT=''
OUTPUT=''
KEY=''
QUIET=''
REST=''
parse() {
	OPTIND=$(($#+1))
	while OPTARG= && [ "${REST}" != x ] && [ $# -gt 0 ]; do
		set -- "${1%%\=*}" "${1#*\=}" "$@"
		while [ ${#1} -gt 2 ]; do
			case $1 in (*[!a-zA-Z0-9_-]*) break; esac
			case '--header' in
				"$1") OPTARG=; break ;;
				$1*) OPTARG="$OPTARG --header"
			esac
			case '--payload' in
				"$1") OPTARG=; break ;;
				$1*) OPTARG="$OPTARG --payload"
			esac
			case '--signature' in
				"$1") OPTARG=; break ;;
				$1*) OPTARG="$OPTARG --signature"
			esac
			case '--all' in
				"$1") OPTARG=; break ;;
				$1*) OPTARG="$OPTARG --all"
			esac
			case '--key' in
				"$1") OPTARG=; break ;;
				$1*) OPTARG="$OPTARG --key"
			esac
			case '--quiet' in
				"$1") OPTARG=; break ;;
				$1*) OPTARG="$OPTARG --quiet"
			esac
			case '--help' in
				"$1") OPTARG=; break ;;
				$1*) OPTARG="$OPTARG --help"
			esac
			case '--version' in
				"$1") OPTARG=; break ;;
				$1*) OPTARG="$OPTARG --version"
			esac
			break
		done
		case ${OPTARG# } in
			*\ *)
				eval "set -- $OPTARG $1 $OPTARG"
				OPTIND=$((($#+1)/2)) OPTARG=$1; shift
				while [ $# -gt "$OPTIND" ]; do OPTARG="$OPTARG, $1"; shift; done
				set "Ambiguous option: $1 (could be $OPTARG)" ambiguous "$@"
				echo "$1" >&2
				exit 1 ;;
			?*)
				[ "$2" = "$3" ] || OPTARG="$OPTARG=$2"
				shift 3; eval 'set -- "${OPTARG# }"' ${1+'"$@"'}; OPTARG= ;;
			*) shift 2
		esac
		case $1 in
			--?*=*) OPTARG=$1; shift
				eval 'set -- "${OPTARG%%\=*}" "${OPTARG#*\=}"' ${1+'"$@"'}
				;;
			--no-*|--without-*) unset OPTARG ;;
			-[k]?*) OPTARG=$1; shift
				eval 'set -- "${OPTARG%"${OPTARG#??}"}" "${OPTARG#??}"' ${1+'"$@"'}
				;;
			-[HPSAqhV]?*) OPTARG=$1; shift
				eval 'set -- "${OPTARG%"${OPTARG#??}"}" -"${OPTARG#??}"' ${1+'"$@"'}
				case $2 in --*) set -- "$1" unknown "$2" && REST=x; esac;OPTARG= ;;
		esac
		case $1 in
			'-H'|'--header')
				[ "${OPTARG:-}" ] && OPTARG=${OPTARG#*\=} && set "noarg" "$1" && break
				eval '[ ${OPTARG+x} ] &&:' && OPTARG='header' || OPTARG=''
				OUTPUT="$OPTARG"
				;;
			'-P'|'--payload')
				[ "${OPTARG:-}" ] && OPTARG=${OPTARG#*\=} && set "noarg" "$1" && break
				eval '[ ${OPTARG+x} ] &&:' && OPTARG='payload' || OPTARG=''
				OUTPUT="$OPTARG"
				;;
			'-S'|'--signature')
				[ "${OPTARG:-}" ] && OPTARG=${OPTARG#*\=} && set "noarg" "$1" && break
				eval '[ ${OPTARG+x} ] &&:' && OPTARG='sig' || OPTARG=''
				OUTPUT="$OPTARG"
				;;
			'-A'|'--all')
				[ "${OPTARG:-}" ] && OPTARG=${OPTARG#*\=} && set "noarg" "$1" && break
				eval '[ ${OPTARG+x} ] &&:' && OPTARG='all' || OPTARG=''
				OUTPUT="$OPTARG"
				;;
			'-k'|'--key')
				[ $# -le 1 ] && set "required" "$1" && break
				OPTARG=$2
				KEY="$OPTARG"
				shift ;;
			'-q'|'--quiet')
				[ "${OPTARG:-}" ] && OPTARG=${OPTARG#*\=} && set "noarg" "$1" && break
				eval '[ ${OPTARG+x} ] &&:' && OPTARG='1' || OPTARG=''
				QUIET="$OPTARG"
				;;
			'-h'|'--help')
				usage
				exit 0 ;;
			'-V'|'--version')
				echo "${VERSION}"
				exit 0 ;;
			--)
				shift
				while [ $# -gt 0 ]; do
					REST="${REST} \"\${$(($OPTIND-$#))}\""
					shift
				done
				break ;;
			[-]?*) set "unknown" "$1"; break ;;
			*)
				REST="${REST} \"\${$(($OPTIND-$#))}\""
		esac
		shift
	done
	[ $# -eq 0 ] && { OPTIND=1; unset OPTARG; return 0; }
	case $1 in
		unknown) set "Unrecognized option: $2" "$@" ;;
		noarg) set "Does not allow an argument: $2" "$@" ;;
		required) set "Requires an argument: $2" "$@" ;;
		pattern:*) set "Does not match the pattern (${1#*:}): $2" "$@" ;;
		notcmd) set "Not a command: $2" "$@" ;;
		*) set "Validation error ($1): $2" "$@"
	esac
	echo "$1" >&2
	exit 1
}
usage() {
cat<<-'GETOPTIONSHERE'
Usage: jwt [options...] [token]

Decode and verify JSON Web Tokens
Reads token from argument or stdin if not provided.

Options:
  Output selection (mutually exclusive):
  -H, --header                Display JWT header
  -P, --payload               Display JWT payload (default)
  -S, --signature             Display raw signature
  -A, --all                   Display all parts as JSON

  Verification:
  -k, --key KEY               Verify signature (secret, @file, or @-/- for stdin)
  -q, --quiet                 Suppress warnings
  -h, --help                  
  -V, --version               
GETOPTIONSHERE
}
# Generated by getoptions (END)
# --- end: gengetoptions parser -f ./options.sh parser_definition parse ---
# @end-kcov-exclude

# --- begin: scripts/jwt/decode.sh ---

base64url_to_base64() {
	local input=$1
	local output

	output=${input//-/+}
	output=${output//_/\/}

	local remainder=$((${#output} % 4))
	case $remainder in
		2) printf '%s==' "$output" ;;
		3) printf '%s=' "$output" ;;
		*) printf '%s' "$output" ;;
	esac
}

base64url_decode() {
	local input=$1
	local b64
	b64=$(base64url_to_base64 "$input")
	printf '%s' "$b64" | base64 -d 2>/dev/null
}

jwt_split() {
	local token=$1

	token=${token//[$'\n\r\t ']/}

	if [[ -z $token ]]; then
		echo "jwt: error: empty token" >&2
		return 1
	fi

	local dot_count
	dot_count=$(tr -cd '.' <<<"$token" | wc -c)
	dot_count=${dot_count// /} # trim whitespace from wc
	if [[ $dot_count -ne 2 ]]; then
		echo "jwt: error: invalid JWT format (expected exactly 2 dots)" >&2
		return 1
	fi

	IFS='.' read -r JWT_HEADER_B64 JWT_PAYLOAD_B64 JWT_SIG_B64 <<<"$token"

	if [[ -z $JWT_HEADER_B64 || -z $JWT_PAYLOAD_B64 || -z $JWT_SIG_B64 ]]; then
		echo "jwt: error: invalid JWT format (expected header.payload.signature)" >&2
		return 1
	fi
}

jwt_decode_header() {
	JWT_HEADER=$(base64url_decode "$JWT_HEADER_B64")

	if [[ -z $JWT_HEADER ]]; then
		echo "jwt: error: failed to decode header" >&2
		return 1
	fi

	if [[ ! $JWT_HEADER =~ ^\{.*\}$ ]]; then
		echo "jwt: error: invalid header JSON" >&2
		return 1
	fi

	if [[ $JWT_HEADER =~ \"alg\"[[:space:]]*:[[:space:]]*\"([^\"]+)\" ]]; then
		JWT_ALG=${BASH_REMATCH[1]}
	else
		echo "jwt: error: missing 'alg' in header" >&2
		return 1
	fi
}

jwt_decode_payload() {
	JWT_PAYLOAD=$(base64url_decode "$JWT_PAYLOAD_B64")

	if [[ -z $JWT_PAYLOAD ]]; then
		echo "jwt: error: failed to decode payload" >&2
		return 1
	fi

	if [[ ! $JWT_PAYLOAD =~ ^\{.*\}$ ]]; then
		echo "jwt: error: invalid payload JSON" >&2
		return 1
	fi
}
# --- end: scripts/jwt/decode.sh ---
# --- begin: scripts/jwt/verify.sh ---

# @start-kcov-exclude - only called when version warnings trigger (OpenSSL < 3.x)
jwt_warn() {
	[[ -n "${JWT_QUIET:-}" ]] && return 0
	echo "jwt: warning: $1" >&2
	return 0
}
# @end-kcov-exclude

check_dependencies() {
	local alg=${1:-}

	# @start-kcov-exclude - can't mock PATH to test missing dependencies
	if ! command -v openssl &>/dev/null; then
		echo "jwt: error: openssl not found" >&2
		return 1
	fi

	case $alg in
		ES256 | ES384 | ES512)
			if ! command -v xxd &>/dev/null; then
				echo "jwt: error: xxd not found (required for ECDSA)" >&2
				return 1
			fi
			;;
	esac
	# @end-kcov-exclude
}

get_openssl_major_version() {
	local version_string version
	version_string=$(openssl version 2>/dev/null)
	# @start-kcov-exclude - only triggers on LibreSSL systems
	if [[ "$version_string" == LibreSSL* ]]; then
		echo "0"
		return
	fi
	# @end-kcov-exclude
	version=$(echo "$version_string" | awk '{print $2}')
	echo "${version%%.*}"
}

check_algorithm_support() {
	local alg=$1
	local major_version
	major_version=$(get_openssl_major_version)

	case $alg in
		PS256 | PS384 | PS512 | EdDSA)
			# @start-kcov-exclude - only triggers on OpenSSL < 3.x or LibreSSL
			if [[ "$major_version" -lt 3 ]]; then
				jwt_warn "algorithm '$alg' requires OpenSSL 3.x (found: $(openssl version))"
				return 1
			fi
			# @end-kcov-exclude
			;;
	esac
	return 0
}

get_openssl_digest() {
	case $JWT_ALG in
		HS256 | RS256 | ES256 | PS256) echo "sha256" ;;
		HS384 | RS384 | ES384 | PS384) echo "sha384" ;;
		HS512 | RS512 | ES512 | PS512) echo "sha512" ;;
		EdDSA) echo "" ;; # @kcov-ignore - EdDSA requires OpenSSL 3.x
		# @start-kcov-exclude - verify_signature validates algorithm first
		*)
			echo "jwt: error: unsupported algorithm '$JWT_ALG'" >&2
			return 1
			;;
			# @end-kcov-exclude
	esac
}

verify_hmac() {
	local secret=$1
	local digest expected_sig actual_sig

	digest=$(get_openssl_digest) || return $?

	local signing_input="${JWT_HEADER_B64}.${JWT_PAYLOAD_B64}"
	expected_sig=$(printf '%s' "$signing_input" | openssl dgst -"$digest" -hmac "$secret" -binary | base64 | tr -d '\n' | tr '+/' '-_' | tr -d '=')

	actual_sig=${JWT_SIG_B64//=/}

	if [[ "$expected_sig" != "$actual_sig" ]]; then
		echo "jwt: error: signature verification failed" >&2
		return 1
	fi
}

verify_rsa() {
	local key=$1
	local digest sig_file key_file result=0

	digest=$(get_openssl_digest) || return $?

	sig_file=$(mktemp)
	key_file=$(mktemp)

	base64url_decode "$JWT_SIG_B64" >"$sig_file"
	printf '%s\n' "$key" >"$key_file"

	local signing_input="${JWT_HEADER_B64}.${JWT_PAYLOAD_B64}"
	if ! printf '%s' "$signing_input" | openssl dgst -"$digest" -verify "$key_file" -signature "$sig_file" &>/dev/null; then
		echo "jwt: error: signature verification failed" >&2
		result=1
	fi

	rm -f "$sig_file" "$key_file"
	return $result
}

jwt_sig_to_der() {
	local sig_hex=$1
	local key_bits=$2
	local r_len r_hex s_hex

	case $key_bits in
		256) r_len=64 ;;  # 32 bytes = 64 hex chars
		384) r_len=96 ;;  # 48 bytes = 96 hex chars
		512) r_len=132 ;; # 66 bytes = 132 hex chars (P-521)
		# @start-kcov-exclude - only called with valid key_bits from verify_ecdsa
		*) return 1 ;;
			# @end-kcov-exclude
	esac

	r_hex=${sig_hex:0:$r_len}
	s_hex=${sig_hex:$r_len:$r_len}

	r_hex=$(echo "$r_hex" | sed 's/^0*//')
	s_hex=$(echo "$s_hex" | sed 's/^0*//')

	[[ $((${#r_hex} % 2)) -eq 1 ]] && r_hex="0$r_hex"
	[[ $((${#s_hex} % 2)) -eq 1 ]] && s_hex="0$s_hex"

	[[ ${r_hex:0:1} =~ [89a-fA-F] ]] && r_hex="00$r_hex"
	[[ ${s_hex:0:1} =~ [89a-fA-F] ]] && s_hex="00$s_hex"

	local r_bytes=$((${#r_hex} / 2))
	local s_bytes=$((${#s_hex} / 2))

	local total_len=$((2 + r_bytes + 2 + s_bytes))
	if [[ $total_len -gt 127 ]]; then
		printf '3081%02x02%02x%s02%02x%s' "$total_len" "$r_bytes" "$r_hex" "$s_bytes" "$s_hex"
	else
		printf '30%02x02%02x%s02%02x%s' "$total_len" "$r_bytes" "$r_hex" "$s_bytes" "$s_hex"
	fi
}

verify_ecdsa() {
	local key=$1
	local digest sig_file key_file key_bits result=0

	digest=$(get_openssl_digest) || return $?

	case $JWT_ALG in
		ES256) key_bits=256 ;;
		ES384) key_bits=384 ;;
		ES512) key_bits=512 ;;
	esac

	sig_file=$(mktemp)
	key_file=$(mktemp)

	local sig_hex der_hex
	sig_hex=$(base64url_decode "$JWT_SIG_B64" | xxd -p | tr -d '\n')
	# @start-kcov-exclude - jwt_sig_to_der only fails with invalid key_bits (defensive)
	der_hex=$(jwt_sig_to_der "$sig_hex" "$key_bits") || {
		echo "jwt: error: failed to convert ECDSA signature" >&2
		rm -f "$sig_file" "$key_file"
		return 1
	}
	# @end-kcov-exclude

	echo "$der_hex" | xxd -r -p >"$sig_file"
	printf '%s\n' "$key" >"$key_file"

	local signing_input="${JWT_HEADER_B64}.${JWT_PAYLOAD_B64}"
	if ! printf '%s' "$signing_input" | openssl dgst -"$digest" -verify "$key_file" -signature "$sig_file" &>/dev/null; then
		echo "jwt: error: signature verification failed" >&2
		result=1
	fi

	rm -f "$sig_file" "$key_file"
	return $result
}

verify_pss() {
	local key=$1
	local digest sig_file key_file result=0

	check_algorithm_support "$JWT_ALG" || return $?
	digest=$(get_openssl_digest) || return $?

	sig_file=$(mktemp)
	key_file=$(mktemp)

	base64url_decode "$JWT_SIG_B64" >"$sig_file"
	printf '%s\n' "$key" >"$key_file"

	local signing_input="${JWT_HEADER_B64}.${JWT_PAYLOAD_B64}"
	if ! printf '%s' "$signing_input" | openssl dgst -"$digest" -verify "$key_file" -signature "$sig_file" -sigopt rsa_padding_mode:pss -sigopt rsa_pss_saltlen:-1 &>/dev/null; then
		echo "jwt: error: signature verification failed" >&2
		result=1
	fi

	rm -f "$sig_file" "$key_file"
	return $result
}

verify_eddsa() {
	local key=$1
	local sig_file input_file key_file result=0

	check_algorithm_support "EdDSA" || return $?

	sig_file=$(mktemp)
	input_file=$(mktemp)
	key_file=$(mktemp)

	base64url_decode "$JWT_SIG_B64" >"$sig_file"

	local signing_input="${JWT_HEADER_B64}.${JWT_PAYLOAD_B64}"
	printf '%s' "$signing_input" >"$input_file"
	printf '%s\n' "$key" >"$key_file"

	if ! openssl pkeyutl -verify -pubin -inkey "$key_file" -rawin -in "$input_file" -sigfile "$sig_file" &>/dev/null; then
		echo "jwt: error: signature verification failed" >&2
		result=1
	fi

	rm -f "$sig_file" "$input_file" "$key_file"
	return $result
}

verify_signature() {
	local key=$1

	check_dependencies "$JWT_ALG" || return $?

	case $JWT_ALG in
		HS256 | HS384 | HS512)
			verify_hmac "$key"
			;;
		RS256 | RS384 | RS512)
			verify_rsa "$key"
			;;
		ES256 | ES384 | ES512)
			verify_ecdsa "$key"
			;;
		PS256 | PS384 | PS512)
			verify_pss "$key"
			;;
		EdDSA)
			verify_eddsa "$key"
			;;
		# @start-kcov-exclude - jwt_decode_header validates alg exists; defensive only
		*)
			echo "jwt: error: unsupported algorithm '$JWT_ALG'" >&2
			return 1
			;;
			# @end-kcov-exclude
	esac
}
# --- end: scripts/jwt/verify.sh ---

parse "$@" || exit 2
eval "set -- $REST"

JWT_QUIET="${QUIET:-}"

verify_key=${KEY:-}
if [[ -n $verify_key ]]; then
	case $verify_key in
		- | @-)
			if [[ $# -eq 0 ]]; then
				echo "jwt: error: token argument required when reading key from stdin" >&2
				exit 1
			fi
			verify_key=$(cat)
			;;
		@*)
			keyfile=${verify_key#@}
			if [[ ! -r $keyfile ]]; then
				echo "jwt: error: cannot read key file '$keyfile'" >&2
				exit 1
			fi
			verify_key=$(<"$keyfile")
			;;
	esac
fi

if [[ $# -gt 0 ]]; then
	token=$1
elif [[ ! -t 0 ]]; then
	read -r token
else
	# @start-kcov-exclude - TTY + no args can't be tested in ShellSpec (uses pipes)
	echo "jwt: error: no token provided" >&2
	exit 1
	# @end-kcov-exclude
fi

jwt_split "$token" || exit $?
jwt_decode_header || exit $?
jwt_decode_payload || exit $?

if [[ -n $verify_key ]]; then
	verify_signature "$verify_key" || exit $?
fi

case ${OUTPUT:-payload} in
	header)
		printf '%s\n' "$JWT_HEADER"
		;;
	payload)
		printf '%s\n' "$JWT_PAYLOAD"
		;;
	sig)
		base64url_decode "$JWT_SIG_B64"
		;;
	all)
		sig_b64=$(base64url_decode "$JWT_SIG_B64" | base64 | tr -d '\n')
		printf '{"header":%s,"payload":%s,"signature":"%s"}\n' \
			"$JWT_HEADER" "$JWT_PAYLOAD" "$sig_b64"
		;;
esac
